# Add env vars here as needed. No Google API key required for the site.

# Image CDN base URL (optional). When set, all site images are served from this URL.
# Do not commit the real value – keep it only in local .env and in your host's env config.
# Example: https://your-cdn.example.com/public
NEXT_PUBLIC_IMAGE_CDN_BASE=https://ik.imagekit.io/jaishreeskinfinitii/isighteyecare/public
